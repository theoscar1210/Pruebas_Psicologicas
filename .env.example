APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# PRODUCCIÓN: APP_ENV=production  APP_DEBUG=false  APP_URL=https://tu-dominio.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# PRODUCCIÓN: LOG_LEVEL=warning  (evita llenar logs con info/debug irrelevante)

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# PRODUCCIÓN: Usar usuario dedicado sin privilegios DROP/CREATE/ALTER:
#   CREATE USER 'pruebas_app'@'localhost' IDENTIFIED BY 'contraseña_fuerte';
#   GRANT SELECT, INSERT, UPDATE, DELETE ON pruebas_psicologicas.* TO 'pruebas_app'@'localhost';
#   FLUSH PRIVILEGES;

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_SECURE_COOKIE=false
# PRODUCCIÓN OBLIGATORIO: SESSION_SECURE_COOKIE=true  (requiere HTTPS — sin esto las sesiones viajan en texto claro)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Groq API — narrativa automática de informes (gratuito)
# Obtén tu key en: console.groq.com
# IMPORTANTE: Rota inmediatamente si fue expuesta en git o logs.
GROQ_API_KEY=

# Backup automatizado (spatie/laravel-backup)
# BACKUP_ARCHIVE_PASSWORD: cifra el ZIP con AES-256 — OBLIGATORIO en producción
BACKUP_ARCHIVE_PASSWORD=
# BACKUP_S3_DISK: nombre del disco S3 en config/filesystems.php (opcional)
# BACKUP_S3_DISK=s3
